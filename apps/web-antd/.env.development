# 端口号
VITE_PORT=5666

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=https://localhost:44318

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=false

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 登录客户端id
VITE_LOGIN_CLIENT_ID=AbpDemo_App

# 登录授权类型
VITE_LOGIN_GRANT_TYPE=password

# 登录权限范围（使用offline_access时服务器会返回一个刷新令牌，使用户不活跃时仍保持会话有效，但存在一定风险）
VITE_LOGIN_SCOPE=AbpDemo offline_access
